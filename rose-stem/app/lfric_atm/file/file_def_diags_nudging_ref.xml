<file_definition>

  <!-- Diagnostic fields - Nudging fields as read from file -->
  <file id="lfric_diagnostics" name="lfric_diagnostics" output_freq="1h" convention="UGRID" enabled=".TRUE.">

    <!-- Full model level diagnostics -->
    <field_group operation="average" freq_op="1ts" prec="4">
      <field field_ref="theta_nudging_ext_ref"/>
      <field field_ref="u_nudging_ext_ref"/>
      <field field_ref="v_nudging_ext_ref"/>
    </field_group>

  </file>

</file_definition>
